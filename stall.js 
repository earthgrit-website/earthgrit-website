// stall.js – EarthGrit Stall Dates
// TO ADD A DATE: copy one object, fill in details, set active: true
// TO HIDE A DATE: set active: false
// Past dates are hidden automatically
// ============================================================

var STALL_DATES = [
{
    name: "Culture Day Event - Shenley Brook End School",
    date: "Thursday 30 April 2026",
    //time: "9am - 3pm",
    location: "Walbank Grove, Shenley Brook End, Milton Keynes MK5 7ZT. ",
    maps: "https://maps.app.goo.gl/UVkdmC6K4JsWmTot5",
    active: true
  },  
{
    name: "Rashan Pani - Brooklands",
    date: "Saturday 1 May 2026",
    time: "10am - 2pm",
    location: " 6 Brooklands Sq, Milton Keynes MK10 7NF",
    maps: "https://maps.app.goo.gl/ksYVaswwbZRVAm5V7",
    active: true
  }

];

(function buildStallDates() {
  var grid = document.getElementById('stall-dates-grid');
  if (!grid) return;
  var today = new Date();
  today.setHours(0, 0, 0, 0);
  var upcoming = STALL_DATES.filter(function(d) {
    if (!d.active) return false;
    var parts = d.date.split(' ');
    var dateStr = parts.slice(1).join(' ');
    var eventDate = new Date(dateStr);
    return eventDate >= today;
  });
  if (!upcoming.length) {
    grid.innerHTML = '<div style="grid-column:1/-1;background:#f5efe6;border-radius:16px;padding:32px;text-align:center;border:1px solid #e8e0d5;"><div style="font-size:2rem;margin-bottom:12px;">📅</div><div style="font-weight:700;color:#2d5a27;margin-bottom:8px;">No upcoming dates listed yet</div><div style="font-size:.9rem;color:#6b6b6b;">Follow us on Instagram or WhatsApp us to find out when we are next near you.</div></div>';
    return;
  }
  grid.innerHTML = upcoming.map(function(d) {
    var card = '<div style="background:#faf7f2;border-radius:16px;padding:24px;border:1px solid #e8e0d5;display:flex;flex-direction:column;gap:10px;">';
    card += '<div style="font-size:1.5rem;">🗓️</div>';
    if (d.name) card += '<div style="font-size:.75rem;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:#c9973a;">' + d.name + '</div>';
    card += '<div style="font-size:1.1rem;font-weight:700;color:#1a1a1a;">' + d.date + '</div>';
    card += '<div style="font-size:.9rem;color:#6b6b6b;">⏰ ' + d.time + '</div>';
    card += '<div style="font-size:.9rem;color:#2d5a27;font-weight:600;">📍 ' + d.location + '</div>';
    if (d.maps) card += '<a href="' + d.maps + '" target="_blank" style="font-size:.85rem;color:#c9973a;font-weight:600;text-decoration:none;margin-top:4px;">View on Map →</a>';
    card += '</div>';
    return card;
  }).join('');
})();